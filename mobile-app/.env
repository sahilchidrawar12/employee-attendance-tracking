# API Configuration
API_BASE_URL=http://localhost:8080/api
WS_BASE_URL=ws://localhost:8080/ws

# Google Maps Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Application Configuration
APP_NAME=Employee Attendance Tracker
APP_VERSION=1.0.0

# Location Configuration
LOCATION_ACCURACY=high
LOCATION_UPDATE_INTERVAL_MS=30000
ZONE_CHECK_INTERVAL_MS=10000

# Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png

# WebSocket Configuration
WS_RECONNECT_INTERVAL=5000
WS_MAX_RETRIES=5

# Secure Storage Keys
KEYSTORE_NAME=attendance_tracker_keystore
KEYSTORE_ENCRYPTION_KEY=your_secure_key