# API Configuration
API_BASE_URL=http://localhost:8080/api

# Application Configuration
APP_NAME=PC Agent
APP_VERSION=1.0.0

# Activity Tracking
SCREENSHOT_INTERVAL=300
KEYBOARD_ACTIVITY_INTERVAL=60
MOUSE_ACTIVITY_INTERVAL=60

# Data Upload
UPLOAD_INTERVAL=300
BATCH_SIZE=50

# Encryption
ENCRYPTION_KEY=your_encryption_key_here_32_chars_min

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# System Configuration
CPU_THRESHOLD=80
MEMORY_THRESHOLD=90
DISK_THRESHOLD=95